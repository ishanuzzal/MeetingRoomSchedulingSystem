<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Meeting_Scheduling_System</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Meeting_Scheduling_System.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tempusdominus-bootstrap-4@5.39.0/build/css/tempusdominus-bootstrap-4.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <script src="https://kit.fontawesome.com/34dda90885.js" crossorigin="anonymous"></script>

</head>
<body>

    <div class="page-wrapper chiller-theme">
        <a id="show-sidebar" class="btn btn-sm btn-dark" href="#">
            <i class="fas fa-bars"></i>
        </a>
        <nav id="sidebar" class="sidebar-wrapper">
            <div class="sidebar-content">
                <div class="sidebar-brand">
                    <div id="close-sidebar">
                        <i class="fas fa-times"></i>
                    </div>
                </div>
                <div class="sidebar-header">
                    <div class="user-info">
                        <span class="user-name">
                            @User.Identity.Name
                        </span>
                        <span class="user-role">Administrator</span>
                    </div>
                </div>
                <div class="sidebar-menu">
                    <ul>
                        <li class="header-menu">
                            <span>General</span>
                        </li>
                        <li class="sidebar-dropdown">
                            <a href="#">
                                <i class="fa fa-tachometer-alt"></i>
                                <span>Meetings</span>

                            </a>
                            <div class="sidebar-submenu">
                                <ul>
                                    <li>
                                        <a asp-controller="Admin" asp-action="PendingBookings">
                                            Pending Bookings
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Admin" asp-action="AcceptedBookings">
                                            Accepted Bookings
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Admin" asp-action="RejectedBookings">
                                            Rejected Bookings
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Admin" asp-action="AllBookingsView">
                                            All Bookings
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </li>


                        <li class="sidebar-dropdown">
                            <a href="#">
                                <i class="fa-solid fas fa-users"></i>
                                <span>Users</span>

                            </a>
                            <div class="sidebar-submenu">
                                <ul>
                                    <li>
                                        <a asp-controller="Admin" asp-action="UploadCsvFile">
                                           Add From CSV
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Admin" asp-action="GetAllUsers">
                                            All Users
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Admin" asp-action="PendingPasswordRequest">
                                            All Pending Password Reset Request
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </li>

                        <li class="sidebar-dropdown">
                            <a href="#">
                                <i class="fas fa-warehouse"></i>
                                <span>Rooms</span>
                            </a>
                            <div class="sidebar-submenu">
                                <ul>
                                    <li>
                                        <a asp-controller="Room" asp-action="AddRoom">
                                            Add Room

                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Room" asp-action="ViewAllRoom">View All Rooms</a>
                                    </li>

                                </ul>
                            </div>
                        </li>
@*                         <li>
                            <a asp-controller="Admin" asp-action="AllRole">
                                <i class="fa fa-regular fa-address-card"></i>
                                <span>All Role</span>
                            </a>
                        </li> *@
                        <li>
                            <a asp-controller="Admin" asp-action="Calendar">
                                <i class="fa fa-calendar"></i>
                                <span>Calendar</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Auth" asp-action="Registration">
                                <i class="fa fa-regular fa-address-card"></i>
                                <span>Registration</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Auth" asp-action="ChangePassword">
                                <i class="fa fa-regular fa-address-card"></i>
                                <span>Change Password</span>
                            </a>
                        </li>
                        <li>
                            <a asp-controller="Admin" asp-action="SystemSetting">
                                <i class="fa fa-regular fa-address-card"></i>
                                <span>System Setting</span>
                            </a>
                        </li>
                        <li>
                            <div class="flex-item px-4">
                                <i class="fa fa-regular fa-address-card" style="color:white"></i>
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="inline-form">
                                    <button type="submit">Logout</button>
                                </form>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>


        </nav>
        <main class="page-content my-2">
            <h2 class="border-bottom mx-3 px-4">Admin Dashboard</h2>
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/js-cookie@3.0.5/dist/js.cookie.min.js"></script>
    <script src="https://kit.fontawesome.com/34dda90885.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    <script src="~/lib/daypilot/daypilot-all.min.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/tempusdominus-bootstrap-4@5.39.0/build/js/tempusdominus-bootstrap-4.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(".sidebar-dropdown > a").click(function () {
            $(".sidebar-submenu").slideUp(200);
            if ($(this).parent().hasClass("active")) {
                $(".sidebar-dropdown").removeClass("active");
                $(this)
                    .parent()
                    .removeClass("active");
            } else {
                $(".sidebar-dropdown").removeClass("active");
                $(this)
                    .next(".sidebar-submenu")
                    .slideDown(200);
                $(this)
                    .parent()
                    .addClass("active");
            }
        });


        $("#close-sidebar").click(function () {
            $(".page-wrapper").removeClass("toggled");
        });

        $("#show-sidebar").click(function () {
            $(".page-wrapper").addClass("toggled");
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>