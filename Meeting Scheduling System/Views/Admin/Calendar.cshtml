@{
}


<style>
    .main {
        display: flex;
        flex-wrap: nowrap;
        align-items: start;
        padding: 0;
        margin: 0;
    }

    .left {
        width: 200px;
        margin-right: 10px;
    }

    .right {
        flex-grow: 1;
        overflow: hidden;
        max-width: 70%;
        margin: 10px;
    }
    .align-center {
        display: flex;
        align-items: end; 
        justify-content: center; 
        text-align: center; 
        height: 100%; 
    }
    .container {
        max-width: 100%;
        margin: 20px auto;
        padding: 0;
    }

    .area_action {
        background-color: #666666;
        color: #ffffff;
        border-radius: 50%;
        padding: 5px;
        cursor: pointer;
        box-sizing: border-box;
    }

    body .calendar_default_event_inner {
        border-radius: 15px;
        background: #999999;
        margin-right: 5px;
        border: 1px solid #666666;
    }

    body .calendar_default_shadow,
    body .calendar_default_shadow_inner {
        border-radius: 15px;
    }

    #RoomAllViewWithColor .room {
        color: #fff;
        text-align: center;
        padding: 15px;
        font-size: 16px;
        border: 1px solid #ccc;
    }

    #RoomAllViewWithColor .room:hover {
        cursor: pointer;
    }

</style>


<div class="modal fade" id="confirmModal" tabindex="-1" role="dialog" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalLabel">Confirmation</h5>
            </div>
            <div class="modal-body" id="confirmModalMessage">
                Are you sure you want to delete this booking?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" id="confirmButton" class="btn btn-danger">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewBooking" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="exampleModalLabel">Schedule</h6>
                <div class="div icons">
                    <button type="button" class="btn shadow-none" id="editBooking" data-id="" data-toggle="modal" data-target="#viewBooking"><i class="fas fa-pencil-alt"></i></button>
                    <button type="button" class="btn shadow-none" id="deleteBooking" data-id=""><i class="far fa-trash-alt"></i></button>
                </div>
            </div>
            <div class="modal-body">
                <h3 id="purpose_show"></h3>
                <p id="date_time"></p>
                <p id="room_show"></p>
                <p id="stats_show"></p>
                <p id="owner_show"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade update" id="createModal" tabindex="-1" role="dialog" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createModalLabel">Create Booking</h5>
                <button type="button" class="close create_close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="errorSummary" class="alert alert-danger d-none" role="alert"></div>

                <div class="form-group">
                    <label for="purpose">Purpose</label>
                    <div class="input-group date" id="purpose" data-target-input="nearest">
                        <input type="text" class="form-control" data-target="#purpose" />
                        <div class="input-group-append" data-target="#purpose" data-toggle="purpose"></div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="datetimepicker1">Start Time</label>
                    <div class="input-group date" id="datetimepicker1" data-target-input="nearest">
                        <input type="text" class="form-control datetimepicker-input" data-target="#datetimepicker1" readonly />
                        <div class="input-group-append" data-target="#datetimepicker1" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fas fa-calendar-alt"></i></div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="datetimepicker2">End Time</label>
                    <div class="input-group date" id="datetimepicker2" data-target-input="nearest">
                        <input type="text" class="form-control datetimepicker-input" data-target="#datetimepicker2" readonly />
                        <div class="input-group-append" data-target="#datetimepicker2" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fas fa-calendar-alt"></i></div>
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="room">Room</label>
                            <select class="form-control" id="room">
                                <option value="">Select a Room</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group col-md-6">
                        <label for="Participations">Participations</label>
                        <div class="input-group" id="participations" data-target-input="nearest">
                            <input type="number" class="form-control" data-target="#participations" />
                            <div class="input-group-append" data-target="#participations"></div>
                        </div>
                    </div>

                    <div class="form-group">
                        @Html.AntiForgeryToken()
                    </div>

                </div>
                <div class="form-group">
                    <label for="UserSelect">Assigned to</label>
                    <select class="form-control" id="UserSelect">
                        <option value="">User Select</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary create_close" data-dismiss="modal">Close</button>
                <button type="button" id="addBooking" class="btn btn-primary">Save changes</button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade update" id="updateModal" tabindex="-1" role="dialog" aria-labelledby="updateModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createModalLabel">Update Booking</h5>
                <button type="button" class="close create_close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="errorSummary2" class="alert alert-danger d-none" role="alert"></div>

                <div class="form-group">
                    <label for="purpose2">Purpose</label>
                    <div class="input-group date" id="purpose2" data-target-input="nearest">
                        <input type="text" class="form-control" data-target="#purpose2" />
                        <div class="input-group-append" data-target="#purpose2" data-toggle="purpose2"></div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="datetimepickerUpdate1">Start Time</label>
                    <div class="input-group date" id="datetimepickerUpdate1" data-target-input="nearest">
                        <input type="text" class="form-control datetimepicker-input" data-target="#datetimepickerUpdate1" readonly />
                        <div class="input-group-append" data-target="#datetimepickerUpdate1" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fas fa-calendar-alt"></i></div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="datetimepickerUpdate2">End Time</label>
                    <div class="input-group date" id="datetimepickerUpdate2" data-target-input="nearest">
                        <input type="text" class="form-control datetimepicker-input" data-target="#datetimepickerUpdate2" readonly />
                        <div class="input-group-append" data-target="#datetimepickerUpdate2" data-toggle="datetimepicker">
                            <div class="input-group-text"><i class="fas fa-calendar-alt"></i></div>
                        </div>
                    </div>
                </div>
      

                <div class="form-row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="room">Room</label>
                            <select class="form-control" id="room2">
                                <option value="">Select a Room</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group col-md-6">
                        <label for="Participations2">Participations</label>
                        <div class="input-group" id="participations2" data-target-input="nearest">
                            <input type="number" class="form-control" data-target="#participations2" />
                            <div class="input-group-append" data-target="#participations2"></div>
                        </div>
                    </div>


                </div>

                <div class="form-group">
                    <label for="UserSelect2">Assigned to</label>
                    <select class="form-control" id="UserSelect2">
                        <option value="">User Select</option>
                    </select>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary create_close" data-dismiss="modal">Close</button>
                <button type="button" id="updateMeeting" class="btn btn-primary">Update</button>
            </div>
        </div>
    </div>
</div>

<div class="main">
    <div class="row">
        <div class="left col-md-2">
            <div class="col-12 mb-3">
                <div id="datepicker"></div>
            </div>
            <div id="RoomAllViewWithColor" class="d-flex flex-wrap h-30 w-75 ml-3">
            </div>
        </div>

        <div id="right" class="right col-md-10">
            <div class="row">
                <div class="buttons col-md-5 my-2">
                    <button id="previous" class="btn btn-primary">Previous</button>
                    <button id="today" class="btn btn-secondary">Today</button>
                    <button id="next" class="btn btn-primary">Next</button>
                    <button id="weekViewButton" class="btn btn-info">WV</button>
                    <button id="dayViewButton" class="btn btn-primary">DV</button>
                    <button id="resourcsViewButton" class="btn btn-warning">RV</button>
                </div>
                 <div class="col-md-5 text-start">
                    <h5 id="selectedDateTime">Selected Date and Time</h5>
                 </div>               
                <div class="col-md-2 form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" checked>
                  <label class="form-check-label" for="flexSwitchCheckChecked">Calendar Refresh</label>
                </div>
            </div>
            <div id="calendar"></div>
        </div>
    </div>
</div>

@section Scripts{
    <script>
        $(document).ready(function () {
            loadRoomBesideData();
            const calendar = new DayPilot.Calendar("calendar", {
                viewType: "Resources",
                durationBarVisible: false,
                onTimeRangeSelected: async (args) => {
                    calendar.clearSelection();
                    MeetingCreate(args)
                },

                onEventClick: async function (args) {
                    const roomList = calendar.columns.list
                    const text = args.e.data.text;
                    const startTime = new Date(args.e.data.start).toLocaleString();
                    const endTime = new Date(args.e.data.end).toLocaleString();
                    const room = roomList.find(item => item.id == args.e.data.resource).name;
                    const ownerEmail = args.e.data.tags.email;
                    const status = args.e.data.tags.status;
                    const bookingId = args.e.data.id;

                    $("#purpose_show").text(args.e.data.text);
                    $("#date_time").text(startTime + " - " + endTime);
                    $("#room_show").text("Room: " + room);
                    $("#stats_show").text("Status: " + status);
                    $("#owner_show").text("Owner: " + ownerEmail);

                    if (status != "Pending") 
                    {
                        $("#editBooking, #deleteBooking").hide();
                    }
                    else 
                    {
                        $("#editBooking").data("id", bookingId);
                        $("#deleteBooking").data("id", bookingId);
                        $("#updateMeeting").data("id", bookingId);
                        $("#editBooking, #deleteBooking").show();
                    }
                    $("#viewBooking").modal("show")

                },

                onBeforeEventRender: args => {
                    args.data.moveDisabled = true;
                    args.data.resizeDisabled = true;
                    args.data.eventResizeHandling = "disabled";
                    args.data.borderColor = "darker";
                    if (args.data.tags.status == "Pending") {
                        args.data.areas = [
                            {
                                left: 5,
                                bottom: 5,
                                width: 20,
                                height: 20,
                                symbol: "~/lib/icons/hourglass-half-solid.svg",
                                style: "border-radius: 50%",
                                backColor: "#FFFFFF",
                                fontColor: "##FFFDD0",
                                padding: 4
                            }
                        ]
                    } 
                },

                onAfterEventRender: args => {
                    args.div.dataset.eventId = args.e.data.id;
                },

                onBeforeHeaderRender: args => {
                    if(calendar.viewType=="Resources"){
                        args.header.backColor = calendar.columns.list.find(item => item.id == args.header.id).colorCode;
                    }
                   
                    args.header.verticalAlignment = "middle";
                },

                headerHeight: 60,
            });

            calendar.init();

            const datepicker = new DayPilot.Navigator("datepicker", {
                selectMode: "Day",
                showMonths: 1,
                skipMonths: 1,
                onTimeRangeSelected: args => {
                    calendar.update({
                        startDate: args.start,
                    });

                    app.loadCalendarData();
                },
            });

            datepicker.init();

            const app = {
                elements: {       
                    previous: document.getElementById("previous"),
                    today: document.getElementById("today"),
                    next: document.getElementById("next")
                },
                async loadCalendarData() {
                    const formatedDate = new Date(datepicker.selectionDay.value).toLocaleDateString("en-US", {
                        weekday: 'long',
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    });

                    $("#selectedDateTime").text(formatedDate);
                    const currentStartDate = calendar.startDate; 
                    const dayOfWeek = currentStartDate.dayOfWeek(); 
                    const weekStart = currentStartDate.addDays(-dayOfWeek); 
                    const weekEnd = weekStart.addDays(6); 

                    let eventUrl = `/api/Booking/GetAllActiveBookings?start=${currentStartDate}&end=${currentStartDate}`;
                    if (calendar.viewType == "Week") {
                        eventUrl = `/api/Booking/GetAllActiveBookings?start=${weekStart}&end=${weekEnd}`;
                    }

                    let promiseEvents = DayPilot.Http.get(`${eventUrl}`);
                    const promiseResources = DayPilot.Http.get("/api/Booking/GetAllRoomApi");
                    const [{ data: columns }, { data: eventsFromApi }] = await Promise.all([promiseResources, promiseEvents]);
                    const events = [];
                    for (let i = 0; i < eventsFromApi.length; i++) {
                        const event = {
                            id: eventsFromApi[i].id,
                            start: eventsFromApi[i].startTime,
                            end: eventsFromApi[i].endTime,
                            resource: eventsFromApi[i].roomId,
                            text: eventsFromApi[i].purpose,
                            backColor: eventsFromApi[i].colorCode,
                            tags: {
                                email: eventsFromApi[i].userEmail,
                                status: eventsFromApi[i].status,
                                isOwner: eventsFromApi[i].isOwner
                            }
                        }
                        events.push(event);
                    }
                    calendar.update({
                        columns,
                        events,
                    });

                },

                addHandlers() 
                {
                    app.elements.previous.addEventListener("click", () => {
                        const current = datepicker.selectionDay;
                        datepicker.select(current.addDays(-1));
                    });
                    app.elements.next.addEventListener("click", () => {
                        const current = datepicker.selectionDay;
                        datepicker.select(current.addDays(1));
                    });
                    app.elements.today.addEventListener("click", () => {
                        datepicker.select(DayPilot.Date.today());
                    });
                },
                init() {
                    app.addHandlers();
                    app.loadCalendarData();
                }
            };
            app.init();

            $('#datetimepicker1').datetimepicker({
                format: 'YYYY/MM/DD hh:mm A',
                stepping: 30,
                allowInputToggle: true
            });
            $('#datetimepicker1 input').on('keydown', function (e) {
                e.preventDefault();
            });
            $('#datetimepicker2').datetimepicker({
                stepping: 30,
                format: 'YYYY/MM/DD hh:mm A',
                allowInputToggle: true,
            });
            $('#datetimepicker2 input').on('keydown', function (e) {
                e.preventDefault(); 
            });

            $('#datetimepickerUpdate1').datetimepicker({
                stepping: 30,
                format: 'YYYY/MM/DD hh:mm A',
                allowInputToggle: true
            });
            $('#datetimepickerUpdate1 input').on('keydown', function (e) {
                e.preventDefault();
            });
            $('#datetimepickerUpdate2').datetimepicker({
                stepping: 30,
                format: 'YYYY/MM/DD hh:mm A',
                allowInputToggle: true
            });
            $('#datetimepickerUpdate2 input').on('keydown', function (e) {
                e.preventDefault(); 
            });

            function MeetingCreate(event) {
                loadDropdownData();
                $('#createModal').modal('show');
                const formattedStartTime = new moment(new Date(event.start)).format("YYYY/MM/DD hh:mm A");
                const formatedEndTime = new moment(new Date(event.end)).format("YYYY/MM/DD hh:mm A");
                $('#datetimepicker1 input').val(formattedStartTime);
                $('#datetimepicker2 input').val(formatedEndTime);
                if (calendar.viewType == "Resources") {
                    $('#room').val(event.resource);
                } 
            }

            $("#editBooking").click(function () {
                loadDropdownDataOnUpdate()
                const bookingId = $(this).data("id");
                $('#viewBooking').modal('hide');
                $.ajax({
                    type: 'GET',
                    url: `/api/Booking/GetBooking/${bookingId}`,
                })
                .done((data) => {
                    const formatedStartTime = new moment(new Date(data.startTime)).format("YYYY/MM/DD hh:mm A");
                    const formatedEndTime = new moment(new Date(data.endTime)).format("YYYY/MM/DD hh:mm A");
                    const purpose = data.purpose;
                    const participation = data.numberOfParticipation;
                    const room = data.roomId;
                    var ownerMail = data.appUserId;
                    $('#datetimepickerUpdate1 input').val(formatedStartTime);
                    $('#datetimepickerUpdate2 input').val(formatedEndTime);
                    $("#purpose2 input").val(purpose)
                    $("#participations2 input").val(participation);
                    $("#room2").val(room);
                    $("#UserSelect2").val(ownerMail);
                    $('#updateModal').modal('show');
                })
                .fail((err) => {
                        $("#right").prepend(`<div class="alert alert-danger alert-dismissible fade show w-1000" id="edit_alert" role="alert">
                                                <strong id="messageFromApi">${err.responseText}</strong>
                                                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                                    <span aria-hidden="true">&times;</span>
                                                </button>
                                                </div>`
                        )
                        $("#edit_alert").fadeOut(5000, function () {
                            $(this).alert('close');
                        });
                })

            })

            $("#deleteBooking").click(function () 
            {
                const bookingId = $(this).data("id");
                $('#viewBooking').modal('hide');
                showConfirmModal(`Are you sure you want to delete this?`, function (result) 
                {
                    if (result==true) {
                        $.ajax({
                            type: 'DELETE',
                            url: `/api/Booking/DeleteBooking/${bookingId}`,
                        })
                        .done((data) => {
                            app.loadCalendarData();
                        })
                        .fail((err) => {
                            $("#right").prepend(`<div class="alert alert-danger alert-dismissible fade show w-1000" id="delete_alert" role="alert">
                                        <strong id="messageFromApi">${err.responseText}</strong>
                                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                            <span aria-hidden="true">&times;</span>
                                        </button>
                                        </div>`
                            )

                            $("#delete_alert").fadeOut(5000, function () {
                                $(this).alert('close');
                            });
                        })
                    }
                })
            })

            $('#addBooking').click(function () 
            {
                const startTime = $('#datetimepicker1 input').val();
                const endTime = $('#datetimepicker2 input').val();
                const purpose = $("#purpose input").val()
                const room = $("#room").val()
                const participations = $("#participations input").val();
                const assignedTo = $("#UserSelect").val();
                let errors = [];
                $('#errorSummary').addClass("d-none");
                let re = new RegExp("^[a-zA-Z0-9_ ]*$");
                
                if (!startTime) errors.push("Start time is required.");
                if (!endTime) errors.push("End time is required.");
                if (!purpose) errors.push("Purpose is required");
                if (!re.test(purpose)) errors.push("Purpose can only have alphabet,digit,underscore");
                if (!room) errors.push("Room is required");
                if (!participations) errors.push("Participations is required")
                if (!assignedTo) errors.push("AssignedTo to is required")

                if (startTime && endTime && moment(startTime).isSameOrAfter(moment(endTime))) {
                    errors.push("End time must be after start time.");
                }

                const antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();
                const events = {
                    Purpose: purpose.trim(),
                    StartTime: new Date(moment(startTime)).toLocaleString(),
                    EndTime: new Date(moment(endTime)).toLocaleString(),
                    RoomId: room,
                    NumberOfParticipation: participations,
                    Appuserid: assignedTo,
                    __RequestVerificationToken: antiForgeryToken,
                };

                if (errors.length > 0) {
                    $('#errorSummary').html(errors.join("<br>")).removeClass("d-none");
                }
                else 
                {
                    showConfirmModal(`Saved: Start - ${startTime}, End - ${endTime}`, function (result) 
                    {
                        if(result==true){
                            $.ajax({
                                type: 'POST',
                                url: '/api/Booking/AddBookingByAdmin',
                                data: events,
                            })
                            .done((data) => {
                                app.loadCalendarData();
                            })
                            .fail((err) => {
                                $("#right").prepend(`<div class="alert alert-danger alert-dismissible fade show w-1000" id="create_alert" role="alert">
                                            <strong id="messageFromApi">${err.responseText}</strong>
                                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                                <span aria-hidden="true">&times;</span>
                                            </button>
                                </div>`)
                                $("#create_alert").fadeOut(5000, function () {
                                    $(this).alert('close');
                                });

                            })
                        }
                    })
                    $('#createModal').modal('hide');
                }
            });

            $('#updateMeeting').click(function (event) {
                const startTime = $('#datetimepickerUpdate1 input').val();
                const endTime = $('#datetimepickerUpdate2 input').val();
                const purpose = $("#purpose2 input").val()
                const room = $("#room2").val()
                const participations = $("#participations2 input").val();
                const assignedTo = $("#UserSelect2").val();
                const bookingId = $(this).data("id");
                let errors = [];
                let re = new RegExp("^[a-zA-Z0-9_ ]*$");

                if (!startTime) errors.push("Start time is required.");
                if (!endTime) errors.push("End time is required.");
                if (!purpose) errors.push("Purpose is required");
                if (!re.test(purpose)) errors.push("Purpose can only have alphabet,digit,underscore");
                if (!room) errors.push("Room is required");
                if (!participations) errors.push("Participations is required")
                if (!assignedTo) errors.push("AssignedTo to is required")
                const antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

                if (startTime && endTime && moment(startTime).isSameOrAfter(moment(endTime))) 
                {
                    errors.push("End time must be after start time.");
                }

                const events = {
                    Purpose: purpose.trim(),
                    StartTime: new Date(moment(startTime)).toLocaleString(),
                    EndTime: new Date(moment(endTime)).toLocaleString(),
                    RoomId: room,
                    NumberOfParticipation: participations,
                    Appuserid: assignedTo,
                    __RequestVerificationToken: antiForgeryToken
                };

                if (errors.length > 0) 
                {
                    $('#errorSummary2').html(errors.join("<br>")).removeClass("d-none");
                }
                else 
                {
                    showConfirmModal(`Saved: Start - ${startTime}, End - ${endTime}`, function (result) {
                        if (result == true) 
                        {
                            $.ajax({
                                type: 'PUT',
                                url: `/api/Booking/UpdateBookingByAdmin/${bookingId}`,
                                data: events,
                            })
                            .done((data) => {
                                app.loadCalendarData();
                            })
                            .fail((err) => 
                            {
                                $("#right").prepend(`<div class="alert alert-danger alert-dismissible fade show w-1000" id="update_alert" role="alert">
                                    <strong id="messageFromApi">${err.responseText}</strong>
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                    </div>`)
                                $("#update_alert").fadeOut(5000, function () {
                                    $(this).alert('close');
                                });
                            })
                        }
                    })

                    $('#updateModal').modal('hide');
                }
            });

            $('#createModal').on('hide.bs.modal', function () {
                $("#purpose input").val("")
                $("#participations input").val("");
                $("#room").val("")
                $("#UserSelect").val("");
                $('#errorSummary').addClass("d-none");
            });

            $('#updateModal').on('hide.bs.modal', function () {
                $("#purpose2 input").val("")
                $("#participations2 input").val("");
                $("#room2").val("")
                $("#UserSelect2").val("");
                $('#errorSummary2').addClass("d-none");
            });

            function showConfirmModal(message, callback) {
                $("#confirmModalMessage").text(message);
                $('#confirmModal').modal('show');
                $('#confirmButton').off('click').on('click', function () {
                    $('#confirmModal').modal('hide');
                    callback(true)
                });
            }

            function loadDropdownData() 
            {
                let rooms, userEmails;
                $.get("/api/Booking/GetAllRoomApi", function (data, status) 
                {
                    rooms = data
                    $("#room").empty();
                    rooms.forEach(function (item) 
                    {
                        $('#room').append(
                            $('<option>', 
                            {
                                value: item.id,
                                text: item.name.split()
                            })
                        );
                    }); 
                });

                $.get("/api/Booking/GetAllUsersEmail", function (data, status) 
                {
                    userEmails = data;
                    $("#UserSelect").empty();
                    $('#UserSelect').append(
                        $('<option>', {
                            value: '',
                            text: "Select a User"
                        })
                    );
                    userEmails.forEach(function (item) {
                        $('#UserSelect').append(
                            $('<option>', {
                                value: item.id,
                                text: item.email
                            })
                        );
                    });
                });
            }

            function loadDropdownDataOnUpdate() {
                let rooms, userEmails;
                $.get("/api/Booking/GetAllRoomApi", function (data, status) 
                {
                    rooms = data
                    $("#room2").empty();
                    $('#room2').append(
                        $('<option>', {
                            value: "",
                            text: "Select a Room"
                        })
                    );
                    rooms.forEach(function (item) 
                    {
                        $('#room2').append(
                            $('<option>', {
                                value: item.id,
                                text: item.name
                            })
                        );

                    });

                });

                $.get("/api/Booking/GetAllUsersEmail", function (data, status) 
                {
                    userEmails = data;
                    $("#UserSelect2").empty();
                    $('#UserSelect2').append(
                        $('<option>', 
                        {
                            value: "",
                            text: "Select a User"
                        })
                    );

                    userEmails.forEach(function (item) {
                        $('#UserSelect2').append(
                            $('<option>', {
                                value: item.id,
                                text: item.email
                            })
                        );
                    });
                });
            }

            function loadRoomBesideData() 
            {
                $.get("/api/Booking/GetAllRoomApi", function (data, status) 
                {
                    let rooms = data;
                    rooms.forEach(function (item) 
                    {
                        $('#RoomAllViewWithColor').append(
                            `<div id="${item.id}" style="background-color:${item.colorCode}; color:black;" class="room col-12 col-sm-12">
                                    ${item.name}
                                </div>`
                        );
                    });
                });
            }

            $("#weekViewButton").click(function () 
            {
                calendar.viewType = "Week";
                app.loadCalendarData();
            })
            $("#resourcsViewButton").click(function () {
                calendar.viewType = "Resources";
                app.loadCalendarData();
            })
            $("#dayViewButton").click(function () {
                calendar.viewType = "Day";
                app.loadCalendarData();
            })

            let interval;
            interval = setInterval(app.loadCalendarData, 10000);

            $("#flexSwitchCheckChecked").change(function () {
                if ($(this).is(":checked")) {
                    clearInterval(interval);
                    interval = setInterval(app.loadCalendarData, 10000);
                } else {
                     clearInterval(interval);
                }
            });

        })
    </script>
}
